a-button:hover {\r\n        background-color: #333333;\r\n        color: #ffffff !important;\r\n      }\r\n\r\n      .footer {\r\n        padding: 40px;\r\n        text-align: center;\r\n        background-color: #ffffff;\r\n        border-top: 1px solid #f0f0f0;\r\n      }\r\n\r\n      .footer-nav {\r\n        display: flex;\r\n        justify-content: center;\r\n        gap: 40px;\r\n        margin-bottom: 40px;\r\n      }\r\n\r\n      .footer-nav a {\r\n        color: #000000 !important;\r\n        text-decoration: none;\r\n        font-size: 18px;\r\n        font-weight: 500;\r\n      }\r\n\r\n      .footer-nav a:hover {\r\n        color: #333333 !important;\r\n      }\r\n\r\n      .footer-logo {\r\n        display: flex;\r\n        align-items: center;\r\n        justify-content: center;\r\n        margin: 0 auto;\r\n      }\r\n\r\n       \r\n      @media (max-width: 600px) {\r\n        .email-container {\r\n          margin: 0;\r\n          border-radius: 0;\r\n        }\r\n\r\n        .header {\r\n          padding: 40px 20px;\r\n        }\r\n\r\n        .main-title {\r\n          font-size: 32px;\r\n        }\r\n\r\n        .subtitle {\r\n          font-size: 16px;\r\n          padding: 0 10px;\r\n        }\r\n\r\n        .footer {\r\n          padding: 30px 20px;\r\n        }\r\n\r\n        .footer-nav {\r\n          flex-direction: column;\r\n          gap: 20px;\r\n        }\r\n\r\n        .footer-nav a {\r\n          font-size: 16px;\r\n        }\r\n      }\r\n    </style>\r\n  </head>\r\n  <body>\r\n    <div class=\"email-container\">\r\n      <div class=\"header\">\r\n        <div class=\"logo-icon\">\r\n          <img\r\n            src=\"https://cdn.lmarena.ai/email-circle-logo.png\"\r\n            alt=\"Arena AI\"\r\n            width=\"50\"\r\n            height=\"50\"\r\n            style=\"display: block\"\r\n          />\r\n        </div>\r\n\r\n        <h1 class=\"main-title\">Verify Your Email</h1>\r\n\r\n        <p class=\"subtitle\">Welcome 